# ═══════════════════════════════════════════════════════════════
# BẢO MẬT — KHÔNG commit lên Git
# ═══════════════════════════════════════════════════════════════

# API keys & secrets
.streamlit/secrets.toml
*.secrets

# Chatbot data — có thể chứa lịch sử user, response leaked
.chat_history.json
.chatbot_cache.json

# Paper trading state — sổ giao dịch ảo riêng từng máy
paper_state.json

# Dữ liệu cá nhân hoá per-user — KHÔNG bao giờ commit (chứa hash mật khẩu,
# email, sổ giao dịch riêng, watchlist, alerts, journal của user)
user_data/
*.user.json

# Streamlit Cloud cache local
.streamlit/cache_data/
.streamlit/cache_resource/

# ═══════════════════════════════════════════════════════════════
# Python
# ═══════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# ═══════════════════════════════════════════════════════════════
# IDEs
# ═══════════════════════════════════════════════════════════════
.vscode/
.idea/
.claude/
*.swp
*.swo
.DS_Store

# ═══════════════════════════════════════════════════════════════
# Streamlit
# ═══════════════════════════════════════════════════════════════
.streamlit/config.local.toml

# ═══════════════════════════════════════════════════════════════
# Data cache (tuỳ dự án — có thể commit nếu nhẹ và cần reproduce)
# ═══════════════════════════════════════════════════════════════
# data/cache/
# *.csv.cache
temp_vatly12/

# ═══════════════════════════════════════════════════════════════
# LaTeX build artifacts (báo cáo / mô tả sản phẩm / nhật ký AI)
# ═══════════════════════════════════════════════════════════════
*.aux
*.toc
*.out
*.log
*.bbl
*.blg
*.lof
*.lot
*.synctex.gz
*.fdb_latexmk
*.fls
texput.log
# Minted cache files (Pygments cache khi build PDF code)
_*.data.minted
_minted-*
# Giữ PDF cuối cùng đã build
!*.pdf
